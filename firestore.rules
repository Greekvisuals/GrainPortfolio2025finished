rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidProject(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.videoUrl is string && data.videoUrl.size() <= 1000;
    }

    // Projects collection (Main)
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidProject(request.resource.data);
      allow update: if isSignedIn() && isValidProject(request.resource.data);
      allow delete: if isSignedIn();
    }

    // Real Estate Projects collection
    match /real-estate-projects/{projectId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidProject(request.resource.data);
      allow update: if isSignedIn() && isValidProject(request.resource.data);
      allow delete: if isSignedIn();
    }

    // Messages collection
    match /messages/{messageId} {
      allow create: if true; // Public contact form
      allow read: if isSignedIn(); // Only admins can read messages
    }
  }
}
